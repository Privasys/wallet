{
    "cli": {
        "version": ">= 18.0.0",
        "appVersionSource": "remote",
        "promptToConfigurePushNotifications": true,
        "requireCommit": true
    },
    "build": {
        "base": { "node": "24.12.0", "bun": "1.3.8" },
        "development": {
            "extends": "preview",
            "developmentClient": true,
            "distribution": "internal",
            "ios": { "simulator": false }
        },
        "staging": { "extends": "production", "distribution": "internal" },
        "preview": {
            "extends": "base",
            "distribution": "store",
            "autoIncrement": true,
            "env": { "NODE_ENV": "development", "STAGE": "preview" }
        },
        "production": {
            "extends": "base",
            "distribution": "store",
            "autoIncrement": true,
            "env": { "NODE_ENV": "production", "STAGE": "production" }
        }
    },
    "submit": { "production": {} }
}
