# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
package-lock.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
android/
ios/

# Un-ignore native module sources (expo config plugins + extension code)
!modules/**/ios/
!modules/**/android/

# Pre-built Rust binaries (downloaded during CI, never committed)
modules/native-ratls/ios/lib/
modules/native-ratls/android/src/main/jniLibs/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
