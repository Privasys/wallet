{
    "name": "@privasys/auth",
    "version": "0.1.0",
    "description": "Browser SDK for Privasys Wallet authentication — QR code, push notification, and session management.",
    "license": "AGPL-3.0-only",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js"
        },
        "./iife": "./dist/privasys-auth.iife.js",
        "./frame": {
            "types": "./dist/frame-client.d.ts",
            "import": "./dist/frame-client.js"
        },
        "./frame-client": "./dist/privasys-auth-client.iife.js"
    },
    "scripts": {
        "build": "tsc && npm run build:iife && npm run build:frame-host && npm run build:frame-client",
        "build:iife": "esbuild src/iife.ts --bundle --format=iife --global-name=Privasys --minify --sourcemap --target=es2020 --outfile=dist/privasys-auth.iife.js",
        "build:frame-host": "esbuild src/frame-host.ts --bundle --format=iife --minify --sourcemap --target=es2020 --outfile=dist/privasys-auth-frame.iife.js",
        "build:frame-client": "esbuild src/frame-client.ts --bundle --format=iife --global-name=Privasys --minify --sourcemap --target=es2020 --outfile=dist/privasys-auth-client.iife.js",
        "dev": "tsc --watch"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/qrcode-generator": "^0.0.16",
        "@types/react": "^19.2.14",
        "esbuild": "^0.28.0",
        "react": "^19.0.0",
        "typescript": "~5.9.0"
    },
    "dependencies": {
        "qrcode-generator": "^1.4.4"
    }
}
